# =============================================================================
# COLLABRYX ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE (Required)
# -----------------------------------------------------------------------------
# Get these from: https://app.supabase.com/project/_/settings/api

# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Public anonymous key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (KEEP SECRET! Server-side only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------

# Application URL (used for redirects, OAuth, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment
NODE_ENV=development



# -----------------------------------------------------------------------------
# FEATURE FLAGS (Optional)
# -----------------------------------------------------------------------------

# Enable AI features
# NEXT_PUBLIC_ENABLE_AI_FEATURES=true

# Enable beta features
# NEXT_PUBLIC_ENABLE_BETA_FEATURES=false

# Maintenance mode
# NEXT_PUBLIC_MAINTENANCE_MODE=false

# -----------------------------------------------------------------------------
# PYTHON WORKER (Required for Embeddings & ML Services)
# -----------------------------------------------------------------------------

# Python Worker URL (for embedding generation and ML services)
PYTHON_WORKER_URL=http://localhost:8000
PYTHON_WORKER_PORT=8000

# -----------------------------------------------------------------------------
# EXTERNAL API KEYS (Optional - services have fallbacks)
# -----------------------------------------------------------------------------

# Google Gemini API - AI Mentor
# Get from: https://makersuite.google.com/app/apikey
# Leave empty to use predefined response fallback
GEMINI_API_KEY=

# AI Providers (for AI features)
# Option 1: Use legacy provider keys (backward compatible)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
MINIMAX_API_KEY=your-minimax-key-here
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=MiniMax-M2.7

# Option 2: Use custom provider configuration (recommended)
# Supports any OpenAI-compatible API (Groq, Together, Ollama, etc.) + Anthropic
# Pattern: AI_PROVIDER_N_* where N is the provider index (1, 2, 3...)
# Priority determines failover order (lower = higher priority)

# Example 1: OpenAI (priority 1 - first choice)
# AI_PROVIDER_1_NAME=openai
# AI_PROVIDER_1_API_KEY=sk-...
# AI_PROVIDER_1_BASE_URL=https://api.openai.com/v1
# AI_PROVIDER_1_MODEL=gpt-4o-mini
# AI_PROVIDER_1_MAX_TOKENS=4096
# AI_PROVIDER_1_TEMPERATURE=0.7
# AI_PROVIDER_1_TIMEOUT=60000
# AI_PROVIDER_1_PRIORITY=1

# Example 2: Groq (OpenAI-compatible, priority 2)
# AI_PROVIDER_2_NAME=groq
# AI_PROVIDER_2_API_KEY=gsk_...
# AI_PROVIDER_2_BASE_URL=https://api.groq.com/openai/v1
# AI_PROVIDER_2_MODEL=llama-3.3-70b-versatile
# AI_PROVIDER_2_MAX_TOKENS=4096
# AI_PROVIDER_2_TEMPERATURE=0.7
# AI_PROVIDER_2_TIMEOUT=60000
# AI_PROVIDER_2_PRIORITY=2

# Example 3: Together AI (OpenAI-compatible, priority 3)
# AI_PROVIDER_3_NAME=together
# AI_PROVIDER_3_API_KEY=your-together-key
# AI_PROVIDER_3_BASE_URL=https://api.together.xyz/v1
# AI_PROVIDER_3_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
# AI_PROVIDER_3_MAX_TOKENS=4096
# AI_PROVIDER_3_TEMPERATURE=0.7
# AI_PROVIDER_3_TIMEOUT=60000
# AI_PROVIDER_3_PRIORITY=3

# Example 4: Ollama (self-hosted, OpenAI-compatible)
# AI_PROVIDER_4_NAME=ollama
# AI_PROVIDER_4_API_KEY= # Not required for local Ollama
# AI_PROVIDER_4_BASE_URL=http://localhost:11434/v1
# AI_PROVIDER_4_MODEL=llama3.1
# AI_PROVIDER_4_MAX_TOKENS=4096
# AI_PROVIDER_4_TEMPERATURE=0.7
# AI_PROVIDER_4_TIMEOUT=60000
# AI_PROVIDER_4_PRIORITY=4

# Example 5: Anthropic (native API, priority 5)
# AI_PROVIDER_5_NAME=anthropic
# AI_PROVIDER_5_API_KEY=sk-ant-...
# AI_PROVIDER_5_BASE_URL=https://api.anthropic.com
# AI_PROVIDER_5_MODEL=claude-sonnet-4-20250514
# AI_PROVIDER_5_MAX_TOKENS=4096
# AI_PROVIDER_5_TEMPERATURE=0.7
# AI_PROVIDER_5_TIMEOUT=60000
# AI_PROVIDER_5_PRIORITY=5

# -----------------------------------------------------------------------------
# DEVELOPMENT (Optional)
# -----------------------------------------------------------------------------

# Enable debug mode (shows detailed logs)
DEBUG=false
DEVELOPMENT_MODE=true

# Skip email verification in development
SKIP_EMAIL_VERIFICATION=true

# -----------------------------------------------------------------------------
# SECURITY (Optional)
# -----------------------------------------------------------------------------

# Enable security features
NEXT_PUBLIC_ENABLE_SECURITY=true

# =============================================================================
# NOTES
# =============================================================================
# 
# 1. Variables prefixed with NEXT_PUBLIC_ are exposed to the browser
# 2. Other variables are only available on the server
# 3. Changes to .env.local require restarting the dev server
# 4. For production, set these in your hosting platform's environment settings
# 
# =============================================================================
